# Convex
CONVEX_DEPLOYMENT=           # From `npx convex dev` — e.g., dev:your-project-abc123
NEXT_PUBLIC_CONVEX_URL=      # From Convex dashboard — e.g., https://your-project-abc123.convex.cloud

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # From Clerk dashboard
CLERK_SECRET_KEY=                     # From Clerk dashboard

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/plan
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
